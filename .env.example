# Maki V4 Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# Gemini (cloud AI - primary brain)
# Get API key at: https://aistudio.google.com
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local AI - offline fallback)
OLLAMA_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=qwen2.5:7b

# Provider priority (tries each in order)
AI_PROVIDER_PRIORITY=gemini,ollama,basic

# ── Live web search — OPTIONAL but BIG quality boost ─────────────────────────
# Tavily gives Maki an AI-friendly search API with synthesized answers and
# citations — much better than the free DDG/Wikipedia path for ambiguous or
# specific questions ("current T1 LoL roster", "latest news about X").
# FREE TIER: 1000 searches/month, NO credit card required.
# Sign up at: https://tavily.com   (Get API Key)
TAVILY_API_KEY=
TAVILY_ENABLED=true

# Brave Search (optional 2nd backup; also has a free tier)
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# V19 — six-lane brain router
# ─────────────────────────────────────────────────────────────────────────────

# Cerebras — default brain (V15.2). 1M tok/day free, 8K context cap on free tier.
# Get key at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# Groq — fast casual chat (llama-3.1-8b-instant) + Whisper STT (~200ms).
# 14,400 req/day + 500K tokens/day for chat; Whisper has its own audio-second
# bucket (verified independent of text quota at build time — see
# budget.GROQ_WHISPER_SHARES_TEXT_QUOTA).
# Get key at: https://console.groq.com/
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# GitHub Models — Think-mode brain (premium frontier models, 50-150 req/day).
# Use a GitHub PAT with `models:read` scope.
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Default Think model — swap to gpt-4o, gpt-4.1, o3 if desired.
THINK_MODEL=anthropic/claude-sonnet-4.5
GITHUB_MODELS_DAILY_CAP=50

# NVIDIA NIM — overflow lane (no token cap, 40 RPM, ~1000 starter credits).
# Triggers only when Cerebras 8K guard fires OR Groq/GitHub caps exhausted.
# Get key at: https://build.nvidia.com/
NVIDIA_API_KEY=
NIM_MODEL=nvidia/nemotron-nano-9b-v2

# Vision — local Ollama model. V19 default is qwen3-vl:4b (GUI-agent-trained,
# ~3.3 GB VRAM). Rollback to qwen3-vl:2b if 4b regresses the 8/10 active-app
# screenshot test.
VISION_MODEL=qwen3-vl:4b
VISION_KEEP_ALIVE=30m
